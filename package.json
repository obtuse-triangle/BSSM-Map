{
  "name": "school-floor-map",
  "version": "0.1.0",
  "description": "Interactive school floor plan React component with zoom/pan support",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./data/bssm": {
      "types": "./dist/data/bssm.d.ts",
      "import": "./dist/data/bssm.mjs",
      "require": "./dist/data/bssm.js"
    },
    "./data/campus": {
      "types": "./dist/data/campus.d.ts",
      "import": "./dist/data/campus.mjs",
      "require": "./dist/data/campus.js"
    },
    "./data/campus-wgs84": {
      "types": "./dist/data/campus-wgs84.d.ts",
      "import": "./dist/data/campus-wgs84.mjs",
      "require": "./dist/data/campus-wgs84.js"
    },
    "./data/school-outline": {
      "types": "./dist/data/school-outline.d.ts",
      "import": "./dist/data/school-outline.mjs",
      "require": "./dist/data/school-outline.js"
    },
    "./overlays/maplibre": {
      "types": "./dist/overlays/maplibre.d.ts",
      "import": "./dist/overlays/maplibre.mjs",
      "require": "./dist/overlays/maplibre.js"
    },
    "./overlays/leaflet": {
      "types": "./dist/overlays/leaflet.d.ts",
      "import": "./dist/overlays/leaflet.mjs",
      "require": "./dist/overlays/leaflet.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "tsup"
  },
  "peerDependencies": {
    "leaflet": ">=1.9",
    "maplibre-gl": ">=3",
    "react": ">=18",
    "react-dom": ">=18",
    "react-zoom-pan-pinch": ">=3"
  },
  "peerDependenciesMeta": {
    "maplibre-gl": {
      "optional": true
    },
    "leaflet": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "fast-xml-parser": "^5.8.0",
    "jsdom": "^29.1.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7",
    "zod": "^4.4.3"
  },
  "keywords": [
    "react",
    "floor-plan",
    "school",
    "map",
    "zoom",
    "pan"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "sideEffects": false
}
